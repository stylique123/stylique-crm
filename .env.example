# Frontend
VITE_STYLIQUE_API_BASE_URL=https://your-stylique-api.example.com
VITE_REQUIRE_BACKEND_AUTH=true

# Backend
PORT=8787
STYLIQUE_ALLOWED_ORIGIN=https://your-crm.example.com
STYLIQUE_JWT_SECRET=replace-with-a-long-random-secret
STYLIQUE_ADMIN_PASSWORD=replace-with-a-strong-admin-password
STYLIQUE_DATA_DIR=./server/data
STYLIQUE_MAX_BODY_BYTES=1048576
STYLIQUE_CONNECTOR_TIMEOUT_MS=15000

# Optional per-user auth. If omitted, STYLIQUE_ADMIN_PASSWORD works for every CRM user.
# STYLIQUE_USERS_JSON={"abdullah":{"password":"strong-password","role":"ceo"},"hira":{"password":"strong-password","role":"coo"}}

# Live connector proxy targets. Keep the real keys on the backend only.
CONNECTOR_CLAUDE_URL=
CONNECTOR_CLAUDE_API_KEY=
CONNECTOR_CODEX_URL=
CONNECTOR_CODEX_API_KEY=
CONNECTOR_CLORT_URL=
CONNECTOR_CLORT_API_KEY=
CONNECTOR_BOTEX_URL=
CONNECTOR_BOTEX_API_KEY=
